-- ============================================================
-- Sprout demo seed. Runs automatically on `supabase start` and
-- `supabase db reset` (config.toml -> [db.seed]).
--
-- Creates two nurseries, working email/password logins, a roster, guardianship
-- links, and sample safety records — so the staff app is usable immediately.
--
-- Runs as the superuser, so RLS is bypassed for the insert (this is the one
-- legitimate place to write across tenants).
--
-- Plain statements only — no functions / DO blocks, because the seed runner
-- does not reliably parse dollar-quoted bodies.
--
--   LOGINS (password for all: password123)
--   ┌─────────────────────┬────────┬───────────────────┐
--   │ admin@demo.test      │ admin  │ Sunrise Nursery   │
--   │ staff@demo.test      │ staff  │ Sunrise Nursery   │
--   │ parent@demo.test     │ parent │ guardian of 2 kids│
--   │ staffb@demo.test     │ staff  │ Meadow Nursery    │  (proves tenant isolation)
--   └─────────────────────┴────────┴───────────────────┘
-- ============================================================

-- crypt()/gen_salt() for the password hash (Supabase ships pgcrypto in `extensions`).
create extension if not exists pgcrypto with schema extensions;

-- ---------- Auth users (auth.users) ----------
insert into auth.users (
  instance_id, id, aud, role, email, encrypted_password,
  email_confirmed_at, raw_app_meta_data, raw_user_meta_data,
  created_at, updated_at,
  confirmation_token, email_change, email_change_token_new, recovery_token
) values
  ('00000000-0000-0000-0000-000000000000', 'a0000000-0000-0000-0000-000000000001',
   'authenticated', 'authenticated', 'admin@demo.test',
   extensions.crypt('password123', extensions.gen_salt('bf')),
   now(), '{"provider":"email","providers":["email"]}', '{}', now(), now(), '', '', '', ''),
  ('00000000-0000-0000-0000-000000000000', 'a0000000-0000-0000-0000-000000000002',
   'authenticated', 'authenticated', 'staff@demo.test',
   extensions.crypt('password123', extensions.gen_salt('bf')),
   now(), '{"provider":"email","providers":["email"]}', '{}', now(), now(), '', '', '', ''),
  ('00000000-0000-0000-0000-000000000000', 'a0000000-0000-0000-0000-000000000003',
   'authenticated', 'authenticated', 'parent@demo.test',
   extensions.crypt('password123', extensions.gen_salt('bf')),
   now(), '{"provider":"email","providers":["email"]}', '{}', now(), now(), '', '', '', ''),
  ('00000000-0000-0000-0000-000000000000', 'b0000000-0000-0000-0000-000000000001',
   'authenticated', 'authenticated', 'staffb@demo.test',
   extensions.crypt('password123', extensions.gen_salt('bf')),
   now(), '{"provider":"email","providers":["email"]}', '{}', now(), now(), '', '', '', '')
on conflict (id) do nothing;

-- ---------- Identities (required by GoTrue for password login to resolve) ----------
insert into auth.identities (
  id, user_id, provider_id, identity_data, provider,
  last_sign_in_at, created_at, updated_at
)
select
  gen_random_uuid(), u.id, u.id::text,
  jsonb_build_object('sub', u.id::text, 'email', u.email), 'email',
  now(), now(), now()
from (values
  ('a0000000-0000-0000-0000-000000000001'::uuid, 'admin@demo.test'),
  ('a0000000-0000-0000-0000-000000000002'::uuid, 'staff@demo.test'),
  ('a0000000-0000-0000-0000-000000000003'::uuid, 'parent@demo.test'),
  ('b0000000-0000-0000-0000-000000000001'::uuid, 'staffb@demo.test')
) as u(id, email)
where not exists (
  select 1 from auth.identities i where i.provider = 'email' and i.provider_id = u.id::text
);

-- ---------- Nurseries ----------
insert into nurseries (id, name) values
  ('11111111-1111-1111-1111-111111111111', 'Sunrise Nursery'),
  ('22222222-2222-2222-2222-222222222222', 'Meadow Nursery')
on conflict (id) do nothing;

-- ---------- Profiles (role + tenant) ----------
insert into profiles (id, nursery_id, role, full_name) values
  ('a0000000-0000-0000-0000-000000000001', '11111111-1111-1111-1111-111111111111', 'admin',  'Alex Admin'),
  ('a0000000-0000-0000-0000-000000000002', '11111111-1111-1111-1111-111111111111', 'staff',  'Sam Staff'),
  ('a0000000-0000-0000-0000-000000000003', '11111111-1111-1111-1111-111111111111', 'parent', 'Priya Parent'),
  ('b0000000-0000-0000-0000-000000000001', '22222222-2222-2222-2222-222222222222', 'staff',  'Beth Staff')
on conflict (id) do nothing;

-- ---------- Children ----------
-- NB: seed domain rows use a 'd0000000-…' UUID namespace that NO pgTAP fixture
-- uses. `supabase test db` runs tests against this seeded DB and the tests insert
-- their fixtures with plain INSERT (no ON CONFLICT), so any shared id would abort
-- them with a duplicate-key error. Keep seed ids disjoint from test ids.
insert into children (id, nursery_id, full_name, room) values
  ('d0000000-0000-0000-0000-0000000000c1', '11111111-1111-1111-1111-111111111111', 'Ava Patel',     'Bluebell'),
  ('d0000000-0000-0000-0000-0000000000c2', '11111111-1111-1111-1111-111111111111', 'Noah Khan',     'Bluebell'),
  ('d0000000-0000-0000-0000-0000000000c3', '11111111-1111-1111-1111-111111111111', 'Mia Owusu',     'Sunflower'),
  ('d0000000-0000-0000-0000-0000000000c4', '11111111-1111-1111-1111-111111111111', 'Leo Rossi',     'Sunflower'),
  ('d0000000-0000-0000-0000-0000000000c5', '11111111-1111-1111-1111-111111111111', 'Zara Ahmed',    'Acorn'),
  ('d0000000-0000-0000-0000-0000000000c6', '11111111-1111-1111-1111-111111111111', 'Finn O''Brien', 'Acorn'),
  -- Meadow Nursery (different tenant) — staff@demo will NOT see these.
  ('d0000000-0000-0000-0000-0000000000c7', '22222222-2222-2222-2222-222222222222', 'Olivia Brown',  'Robin')
on conflict (id) do nothing;

-- ---------- Guardianships (parent@demo guardians Ava + Noah) ----------
insert into guardianships (guardian_id, child_id, relationship) values
  ('a0000000-0000-0000-0000-000000000003', 'd0000000-0000-0000-0000-0000000000c1', 'parent'),
  ('a0000000-0000-0000-0000-000000000003', 'd0000000-0000-0000-0000-0000000000c2', 'parent')
on conflict (guardian_id, child_id) do nothing;

-- ---------- Sample safety records for Ava (so those screens have data) ----------
insert into child_medical (child_id, nursery_id, allergies, dietary_needs, medical_notes, version) values
  ('d0000000-0000-0000-0000-0000000000c1', '11111111-1111-1111-1111-111111111111',
   'Peanuts (EpiPen in office)', 'Vegetarian', 'Mild asthma — inhaler as needed', 1)
on conflict (child_id) do nothing;

insert into child_safeguarding (child_id, nursery_id, safeguarding_notes, version) values
  ('d0000000-0000-0000-0000-0000000000c1', '11111111-1111-1111-1111-111111111111',
   'No concerns on file.', 1)
on conflict (child_id) do nothing;

insert into emergency_contacts (id, child_id, nursery_id, contact_name, phone, relationship, priority, version) values
  ('d0000000-0000-0000-0000-0000000000e1', 'd0000000-0000-0000-0000-0000000000c1',
   '11111111-1111-1111-1111-111111111111', 'Raj Patel', '07700900001', 'Grandparent', 1, 1)
on conflict (id) do nothing;
