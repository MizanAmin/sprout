# Public client config for production builds (Vite inlines VITE_* at build time).
# Committed on purpose: the Supabase PUBLISHABLE key and these URLs are exposed in
# the browser bundle regardless, so baking them in makes the build zero-config on
# any host (Cloudflare Pages, Netlify, local `vite build`). NEVER put the Supabase
# secret key or DATABASE_URL here — those are server-only, on the Railway API.
VITE_SUPABASE_URL=https://udmnrzemfcbtiejdqyut.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_vZFs5XUjFpv9GUgGtNPDZA_g9ogy4KQ
VITE_API_URL=https://sprout-production-8da1.up.railway.app/api
